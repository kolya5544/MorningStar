COMPOSE_PROJECT_NAME=morningstar
PUBLIC_BASE_URL=http://localhost:5482
DATABASE_URL=postgresql+psycopg://morningstar:morningstar@db:5432/morningstar
POSTGRES_DB=morningstar
POSTGRES_USER=morningstar
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me
OBJECT_STORAGE_SECRET=change-me
OBJECT_STORAGE_ROOT=/data/object_storage
OBJECT_STORAGE_MAX_FILE_SIZE=5242880
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PBKDF2_ITERS=200000
BACKEND_CORS_ORIGINS=http://localhost:5482,http://localhost:5173
BYBIT_TESTNET=0
BYBIT_TIMEOUT_SEC=8
BYBIT_RETRIES=3
BYBIT_RETRY_DELAY_SEC=0.6
BYBIT_RATE_LIMIT_COUNT=12
BYBIT_RATE_LIMIT_WINDOW_SEC=1
BYBIT_TICKER_TTL_SEC=2
BYBIT_API_KEY=
BYBIT_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
API_STARTUP_DB_RETRIES=20
API_STARTUP_DB_DELAY_SEC=3
FRONTEND_IMAGE=ghcr.io/example/morningstar-web
BACKEND_IMAGE=ghcr.io/example/morningstar-api
IMAGE_TAG=latest

