COMPOSE_PROJECT_NAME=morningstar-prod
PUBLIC_BASE_URL=https://your-domain.example
POSTGRES_DB=morningstar
POSTGRES_USER=morningstar
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg://morningstar:${POSTGRES_PASSWORD}@db:5432/morningstar
JWT_SECRET=replace-with-long-random-secret
OBJECT_STORAGE_SECRET=replace-with-long-random-secret
OBJECT_STORAGE_ROOT=/data/object_storage
BACKEND_CORS_ORIGINS=https://your-domain.example
BYBIT_API_KEY=
BYBIT_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
FRONTEND_IMAGE=ghcr.io/your-github-user/morningstar-web
BACKEND_IMAGE=ghcr.io/your-github-user/morningstar-api
IMAGE_TAG=latest
